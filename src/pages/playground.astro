---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
const base = '/JoudPorfolio';
---
<BaseLayout title="Playground — Joud Azzam">
  <Nav />
  <main id="main-content" style="padding-top:7rem;min-height:80vh;">
    <div class="container" style="padding:3rem 0;">
      <h1 class="section-heading">Playground ☺</h1>
      <p style="color:var(--grey);margin-top:1rem;">Sketches, WIPs, doodles, and behind-the-scenes — coming soon.</p>
      <a href={`${base}/`} style="color:var(--yellow);font-family:var(--font-body);font-size:.85rem;display:block;margin-top:1.5rem;">← Back home</a>
    </div>
  </main>
</BaseLayout>
