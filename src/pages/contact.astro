---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
const base = '/JoudPorfolio';
---
<BaseLayout title="Contact — Joud Azzam">
  <Nav />
  <main id="main-content" style="padding-top:7rem;min-height:80vh;background:#8B0000;">
    <div class="container" style="padding:4rem 0;">
      <h1 class="section-heading" style="color:#fff;">Let's Create<br/>Something</h1>
      <p style="color:rgba(255,255,255,.7);margin-top:1.25rem;max-width:480px;font-family:var(--font-body);font-size:.9rem;line-height:1.75;">Available for freelance work and collaborations — animation, real-time experiences, character work, and more.</p>
      <div style="margin-top:2.5rem;display:flex;flex-direction:column;gap:1rem;">
        <a href="mailto:azzamjoud@gmail.com" style="color:#fff;font-family:var(--font-body);font-size:.9rem;">✉ azzamjoud@gmail.com</a>
        <a href="https://linkedin.com/in/joud-azzam" target="_blank" rel="noopener" style="color:#fff;font-family:var(--font-body);font-size:.9rem;">in linkedin.com/in/joud-azzam</a>
        <span style="color:rgba(255,255,255,.6);font-family:var(--font-body);font-size:.9rem;">◆ Amman, Jordan</span>
      </div>
    </div>
  </main>
</BaseLayout>
