---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
const base = '/JoudPorfolio';

const projects = [
  // ── BRAND VIDEOS ──
  { id:'b01', title:'Brand Video 01', cat:'Brand Videos', type:'vimeo', vid:'1200493332' },
  { id:'b02', title:'Brand Video 02', cat:'Brand Videos', type:'vimeo', vid:'1200493885' },
  // ── LIVE ACTION ──
  { id:'l01', title:'Live Action 01', cat:'Live Action', type:'vimeo', vid:'1200489304' },
  { id:'l02', title:'Live Action 02', cat:'Live Action', type:'vimeo', vid:'1200489346' },
  // ── AI VIDEOS ──
  { id:'ai01', title:'AI Video 01', cat:'AI Videos', type:'youtube', vid:'GPz-XJ-TW1Y' },
  { id:'ai02', title:'AI Video 02', cat:'AI Videos', type:'youtube', vid:'_P6ZKPsQITQ' },
  // ── STYLIZED ──
  { id:'s01', title:'Stylized 01', cat:'Stylized', type:'vimeo', vid:'1200488820' },
  { id:'s02', title:'Stylized 02', cat:'Stylized', type:'vimeo', vid:'1200488833' },
  { id:'s03', title:'Stylized 03', cat:'Stylized', type:'vimeo', vid:'1200488774' },
  { id:'s04', title:'Stylized 04', cat:'Stylized', type:'vimeo', vid:'1200487531' },
  { id:'s05', title:'Stylized 05', cat:'Stylized', type:'vimeo', vid:'1200487527' },
  { id:'s06', title:'Stylized 06', cat:'Stylized', type:'vimeo', vid:'1200487502' },
  { id:'s07', title:'Stylized 07', cat:'Stylized', type:'vimeo', vid:'1200487442' },
  { id:'s08', title:'Stylized 08', cat:'Stylized', type:'vimeo', vid:'1200487443' },
  { id:'s09', title:'Stylized 09', cat:'Stylized', type:'vimeo', vid:'1200487537' },
  // ── SEMI-REALISTIC ──
  { id:'sr01', title:'Semi-Realistic 01', cat:'Semi-Realistic', type:'vimeo', vid:'1200487446' },
  { id:'sr02', title:'Semi-Realistic 02', cat:'Semi-Realistic', type:'vimeo', vid:'1200487442' },
  { id:'sr03', title:'Semi-Realistic 03', cat:'Semi-Realistic', type:'vimeo', vid:'1200488671' },
];
const cats = ['All','Brand Videos','Live Action','AI Videos','Stylized','Semi-Realistic'];
const reelEmbed = 'https://www.youtube.com/embed/nwc-pT6x2Vg?autoplay=1&rel=0';
const pgVideos = [
  { title:'WIP 01', driveId:'1JXRInyVg1bvIVNPwY3TRNFJ1dNYYX8Ua' },
  { title:'WIP 02', driveId:'1aXeRkabyD7HPAH80pbIEQZDMekRVT9Yp' },
  { title:'WIP 03', driveId:'1FaI1Tnp4_RT9RXjgQ-3YAq5AojRiUKFC' },
];
const pgImages = [
  { src:`${base}/images/playground-render.png`, title:'3D Render' },
];
---

<BaseLayout>
  <Nav />

  <!-- ══ INTRO LOADING SCREEN ══ -->
  <div id="intro-screen" aria-hidden="true" role="presentation">
    <video
      id="intro-video"
      src={`${base}/videos/intro.mp4`}
      autoplay
      muted
      playsinline
      preload="auto"
    ></video>
    <div id="intro-skip" aria-label="Skip intro">Skip ↓</div>
  </div>

  <main id="main-content" style="opacity:0;transition:opacity .6s ease;">

    <!-- ══ HERO ══ -->
    <section id="home" class="hero">
      <img src={`${base}/images/splatter-red.png`}    alt="" class="sp sp-red"    aria-hidden="true"/>
      <img src={`${base}/images/splatter-yellow.png`} alt="" class="sp sp-yellow" aria-hidden="true"/>
      <div class="container hero-inner">
        <div class="hero-left">
          <img src={`${base}/images/hero/text-hero.png`} alt="Bringing IDEAS TO LIFE — Through Animation & Storytelling" class="hero-title-img"/>
          <p class="hero-desc">Animator and Visual Storyteller specialising in 3D animation, UA videos and game cinematics.</p>
          <div class="hero-btns">
            <button class="btn-img-link" data-reel={reelEmbed} aria-label="View Reel">
              <img src={`${base}/images/btn-reel.png`} alt="View Reel" class="btn-img"/>
            </button>
            <a href={`${base}/Joud_Azzam_CV.pdf`} download class="btn-img-link" aria-label="Download CV">
              <img src={`${base}/images/btn-cv.png`} alt="Download CV" class="btn-img"/>
            </a>
          </div>
        </div>
        <div class="hero-right">
          <img src={`${base}/images/hero/character.png`} alt="Joud Azzam" class="hero-char"/>
        </div>
      </div>
    </section>

    <!-- ══ SELECTED WORK ══ -->
    <section id="work" class="work-section" aria-labelledby="work-heading">
      <div class="container">
        <div class="work-header">
          <h2 id="work-heading" class="section-heading">Selected Work <span class="star" aria-hidden="true">✦</span></h2>
          <span class="view-all-link">{projects.length} projects</span>
        </div>
        <div class="title-line" aria-hidden="true"></div>
        <div class="filter-row" role="tablist" aria-label="Filter by category">
          {cats.map((c,i) => (
            <button class:list={['filter-btn',{active:i===0}]} data-filter={c} role="tab" aria-selected={i===0?'true':'false'}>{c}</button>
          ))}
        </div>
        <div class="proj-grid" id="proj-grid">
          {projects.map((p,idx) => {
            const embedUrl = p.type === 'youtube'
              ? `https://www.youtube.com/embed/${p.vid}?autoplay=1&rel=0`
              : `https://player.vimeo.com/video/${p.vid}?autoplay=1&title=0&byline=0&portrait=0&dnt=1`;
            return (
              <div class="grid-item" data-cat={p.cat}>
                <article class="proj-card">
                  <button
                    class="proj-thumb-btn"
                    data-embed={embedUrl}
                    data-vid={p.vid}
                    data-type={p.type}
                    data-title={p.title}
                    data-index={idx}
                    aria-label={`Play ${p.title}`}
                  >
                    <div class="thumb-inner">
                      <span class="play-icon" aria-hidden="true">▶</span>
                      <span class="proj-label">{p.cat}</span>
                    </div>
                  </button>
                  <div class="proj-foot"><span class="proj-title">{p.title}</span></div>
                </article>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══ ABOUT ══ -->
    <section id="about" class="about-section" aria-labelledby="about-heading">
      <div class="about-bg" aria-hidden="true"></div>
      <div class="container about-inner">
        <div class="about-photo-wrap">
          <div class="portrait-mask" id="portrait-mask">
            <img src={`${base}/images/hero/portrait.jpg`} alt="Joud Azzam" id="portrait-img" class="portrait-img" draggable="false"/>
          </div>
        </div>
        <div class="about-content">
          <h2 id="about-heading" class="section-heading about-h">About Me</h2>
          <p class="about-body"><span class="about-body-line">I'm a Senior 3D Animator, Team Lead, and Visual Storyteller with 13+ years of experience spanning gaming, marketing, and live entertainment. Now working independently as a freelancer, I bring the full weight of that experience to every project — specialising in Unreal Engine real-time pipelines, character animation, cinematic environments, and high-converting UA content, with an obsessive eye for movement, weight, and timing that makes audiences feel every frame.</span></p>
          <p class="about-body"><span class="about-body-line">My work lives at the intersection of technical precision and raw creative instinct. I've directed cinematic shots, led 3D teams, built full animation pipelines from scratch, and performed as a live Visual DJ — mixing real-time projection mapping at major events like Ayla Aqaba and Dopamine Amman, where the crowd becomes part of the art.</span></p>
          <p class="about-body"><span class="about-body-line">Off the timeline, I'm driven by fashion, photography, and a hunger for new experiences — all of which bleed into the way I see composition, color, and character. I'm always first to experiment, first to lead, and I never stop learning. My long-term mission: to produce animation films and shows for the next generation — stories that teach the things no school ever will.</span></p>
          <div class="stats-row">
            {[['13+','Years Experience'],['UE5','Core Engine'],['2','Live VJ Events']].map(([n,l]) => (
              <div class="stat"><span class="stat-n">{n}</span><span class="stat-l">{l}</span></div>
            ))}
          </div>
          <div class="tool-tags">
            {['Maya','Unreal Engine','Substance Suite','Photoshop','After Effects','Illustrator','MetaHuman','Flow AI','Higgsfield AI'].map(t => <span class="tool-tag">{t}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- ══ PLAYGROUND ══ -->
    <section id="playground" class="playground-section" aria-labelledby="pg-heading">
      <div class="container">
        <div class="pg-header">
          <h2 id="pg-heading" class="section-heading">Playground <span aria-hidden="true">☺</span></h2>
          <p class="pg-desc">Random fun, sketches, WIPs, behind-the-scenes, and things I love.</p>
        </div>
        <div class="pg-grid">
          {pgImages.map(img => (
            <div class="pg-card pg-img-card">
              <button class="pg-img-btn" data-src={img.src} data-title={img.title} aria-label={`View ${img.title} full size`}>
                <img src={img.src} alt={img.title} loading="lazy"/>
              </button>
              <span class="pg-type-badge">Art</span>
            </div>
          ))}
          {pgVideos.map(v => (
            <div class="pg-card pg-vid-card">
              <button class="pg-play-btn" data-drive-id={v.driveId} data-title={v.title} aria-label={`Play ${v.title}`}>
                <span class="pg-play-icon" aria-hidden="true">▶</span>
                <span class="pg-title-lbl">{v.title}</span>
              </button>
              <span class="pg-type-badge">WIP</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══ CONTACT ══ -->
    <section id="contact" class="contact-section" aria-labelledby="contact-heading">
      <div class="container contact-inner">
        <div class="contact-left">
          <h2 id="contact-heading" class="section-heading cta-h">Let's Create<br/>Something</h2>
          <p class="cta-sub">Available for freelance work and collaborations — architectural visualisation, real-time experiences, character animation, and more.</p>
          <div class="contact-links">
            <a href="mailto:azzamjoud@gmail.com" class="cta-item"><span class="cta-icon">✉</span> azzamjoud@gmail.com</a>
            <a href="https://linkedin.com/in/joud-azzam" target="_blank" rel="noopener noreferrer" class="cta-item"><span class="cta-icon">in</span> linkedin.com/in/joud-azzam</a>
            <div class="cta-item"><span class="cta-icon">◆</span> Amman, Jordan</div>
          </div>
        </div>

        <!-- ── CONTACT FORM (Formspree) ── -->
        <div class="contact-form-wrap">
          <form
            id="contact-form"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            novalidate
          >
            <div class="form-field">
              <label for="cf-name">Name</label>
              <input type="text" id="cf-name" name="name" placeholder="Your name" required autocomplete="name"/>
            </div>
            <div class="form-field">
              <label for="cf-email">Email</label>
              <input type="email" id="cf-email" name="email" placeholder="your@email.com" required autocomplete="email"/>
            </div>
            <div class="form-field">
              <label for="cf-type">Project type</label>
              <select id="cf-type" name="project_type">
                <option value="">Select a type</option>
                <option>3D Animation</option>
                <option>UA / Marketing Video</option>
                <option>Character Animation</option>
                <option>Cinematic / Cutscene</option>
                <option>Live VJ / Projection Mapping</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-field">
              <label for="cf-msg">Message / Pitch</label>
              <textarea id="cf-msg" name="message" rows="5" placeholder="Tell me about your project, timeline, and budget..." required></textarea>
            </div>
            <button type="submit" class="form-submit" id="cf-submit">Send Message →</button>
            <p class="form-status" id="form-status" aria-live="polite"></p>
          </form>
        </div>
      </div>
      <p class="foot-copy">© 2026 JOUD AZZAM — ALL RIGHTS RESERVED</p>
    </section>

  </main>

  <!-- ══ VIDEO LIGHTBOX ══ -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Video player" hidden>
    <div class="lb-backdrop"></div>
    <div class="lb-container">
      <button class="lb-close" id="lb-close" aria-label="Close">✕</button>
      <div class="lb-frame">
        <iframe id="lb-iframe" src="" allow="autoplay; fullscreen" allowfullscreen title="Video"></iframe>
      </div>
      <div class="lb-footer">
        <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous video">← Prev</button>
        <span class="lb-title" id="lb-title"></span>
        <button class="lb-nav lb-next" id="lb-next" aria-label="Next video">Next →</button>
      </div>
    </div>
  </div>

  <!-- ══ IMAGE LIGHTBOX ══ -->
  <div id="img-lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
    <div class="lb-backdrop" id="img-lb-backdrop"></div>
    <div class="img-lb-container">
      <button class="lb-close" id="img-lb-close" aria-label="Close">✕</button>
      <img id="img-lb-img" src="" alt="" class="img-lb-img"/>
      <p class="img-lb-title" id="img-lb-title"></p>
    </div>
  </div>

