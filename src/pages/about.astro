---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const skills = {
  'AI & Video': ['ComfyUI', 'Wan 2.6 VACE', 'ControlNet', 'Kling 3.0', 'Runway Gen-4', 'Veo 3', 'Neural Frames'],
  '3D & Animation': ['Blender', 'Maya', 'Cinema 4D', 'MotionBuilder', 'After Effects'],
  'AI Image': ['Midjourney', 'Stable Diffusion', 'Flux Pro', 'IP-Adapter', 'LoRA Training'],
  'Web & Code': ['Astro', 'Next.js', 'TypeScript', 'React', 'Tailwind CSS'],
};
---

<BaseLayout title="About — Joud" description="Creative director and AI filmmaker based in Jordan.">
  <Nav />

  <main id="main-content" class="about-page">
    <div class="container">

      <!-- Header -->
      <div class="about-header">
        <div class="about-photo-wrap">
          <img
            src="/JoudPorfolio/images/hero/portrait.webp"
            alt="Joud — portrait"
            width="420"
            height="520"
            class="about-photo"
            onerror="this.style.display='none'"
          />
        </div>

        <div class="about-intro">
          <span class="tag">About me</span>
          <h1 class="about-title">
            I make the<br/>
            <em class="about-em">impossible visible</em>
          </h1>
          <p class="about-body">
            Creative director and AI filmmaker working at the intersection of
            3D animation, AI image generation, and cinematic storytelling.
            I design multi-agent AI pipelines, build vibe-coded web tools,
            and push what's possible with generative media.
          </p>
          <p class="about-body">
            Based in Jordan. Available for creative direction, AI film production,
            character design systems, and full-stack web projects.
          </p>
          <div class="about-actions">
            <a href="/JoudPorfolio/contact" class="btn-primary">Work with me</a>
            <a href="/JoudPorfolio/cv.pdf" class="btn-ghost" download>Download CV</a>
          </div>
        </div>
      </div>

      <!-- Skills -->
      <section class="skills-section" aria-labelledby="skills-heading">
        <h2 id="skills-heading" class="skills-heading">Tools &amp; skills</h2>
        <div class="skills-grid">
          {Object.entries(skills).map(([category, items]) => (
            <div class="skill-group">
              <h3 class="skill-category">{category}</h3>
              <ul class="skill-list" role="list">
                {items.map(skill => (
                  <li class="skill-item">
                    <span class="skill-dot" aria-hidden="true">·</span>
                    {skill}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about-page { padding-top: 7rem; }

  /* ── Header ── */
  .about-header {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    align-items: center;
    padding: 3rem 0 5rem;
  }

  .about-photo-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    aspect-ratio: 4 / 5;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-intro { display: flex; flex-direction: column; gap: 1.25rem; }

  .about-title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .about-em {
    font-style: italic;
    color: var(--accent);
    font-weight: 300;
  }

  .about-body {
    font-size: 1rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  .about-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .btn-primary {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: #000;
    background: var(--accent);
    padding: 0.75rem 1.75rem;
    border-radius: 100px;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-2px); }

  .btn-ghost {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-1);
    border: 1px solid var(--border-hi);
    padding: 0.75rem 1.75rem;
    border-radius: 100px;
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.05); }

  /* ── Skills ── */
  .skills-section {
    padding: 4rem 0;
    border-top: 1px solid var(--border);
  }

  .skills-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 2rem;
  }

  .skill-category {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .skill-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-2);
    font-family: var(--font-display);
    font-weight: 400;
  }

  .skill-dot { color: var(--accent); font-size: 1.1rem; line-height: 1; }

  @media (max-width: 768px) {
    .about-header {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about-photo-wrap { max-width: 280px; }
  }
</style>
