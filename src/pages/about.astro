---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
const base = '/JoudPorfolio';
---
<BaseLayout title="About — Joud Azzam">
  <Nav />
  <main id="main-content" style="padding-top:7rem;min-height:80vh;background:var(--yellow);">
    <div class="container" style="padding:3rem 0;">
      <h1 class="section-heading" style="color:#000;">About Me</h1>
      <p style="color:rgba(0,0,0,.7);margin-top:1rem;max-width:600px;font-family:var(--font-body);font-size:.9rem;line-height:1.75;">Senior 3D Animator & Team Lead with 13+ years of experience across gaming, marketing, and live entertainment. Full page coming soon.</p>
      <a href={`${base}/Joud_Azzam_CV.pdf`} download style="display:inline-block;margin-top:1.5rem;background:#000;color:var(--yellow);font-family:var(--font-body);font-size:.8rem;font-weight:700;letter-spacing:.08em;padding:.65rem 1.5rem;border-radius:4px;">Download CV ↓</a>
    </div>
  </main>
</BaseLayout>
