---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">© {year} Joud. All rights reserved.</p>
    <nav class="footer-links" aria-label="Social links">
      <a href="https://github.com/Juciferr" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
      <a href="mailto:hello@joud.com" class="footer-link">Email</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 6rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-3);
    font-family: var(--font-display);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.8rem;
    color: var(--text-2);
    font-family: var(--font-display);
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-link:hover { color: var(--accent); }
</style>
